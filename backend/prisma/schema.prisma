  value       Json
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String? @map("created_by")
  updatedById String? @map("updated_by")

  @@map("settings")
}

model Holiday {
