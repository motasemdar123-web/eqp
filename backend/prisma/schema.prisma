model EqpMachine {
  id                   Int      @id @default(autoincrement())
  machineNumber        String   @unique @map("machine_number")
  engineNumber         String?  @map("engine_number")
  machineType          String?  @map("machine_type")
  lastSmr              Int      @default(0) @map("last_smr")
  smrStep              Int      @default(0) @map("smr_step")
  reportCounter        Int      @default(0) @map("report_counter")
  responsibleEngineer  String?  @map("responsible_engineer")
  reports              EqpReport[]
  history              EqpMachineHistory[]
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  createdById          String?  @map("created_by")
  updatedById          String?  @map("updated_by")
  deletedAt            DateTime? @map("deleted_at")

  @@index([machineType])
  @@map("eqp_machines")
}

model EqpReport {
  id             Int       @id @default(autoincrement())
  reportNo       String    @unique @map("report_no")
  machineType    String?   @map("machine_type")
  machineId      Int?      @map("machine_id")
  engineNumber   String?   @map("engine_number")
  smr            Int?
  serviceDate    DateTime? @map("service_date")
  comments       String?
  createdByName  String?   @map("created_by")
  machineNumber  String?   @map("machine_number")
  reportType     String?   @map("report_type")
  serviceType    String?   @map("service_type")
  fileName       String?   @map("file_name")
  fileUrl        String?   @map("file_url")
  machine        EqpMachine? @relation(fields: [machineId], references: [id])
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdById    String?   @map("created_by_user")
  updatedById    String?   @map("updated_by_user")
  deletedAt      DateTime? @map("deleted_at")

  @@index([machineId])
  @@index([createdAt])
  @@index([serviceType])
  @@map("eqp_reports")
}

model EqpMachineHistory {
  id             Int       @id @default(autoincrement())
  machineId      Int?      @map("machine_id")
  operationType  String?   @map("operation_type")
  reportType     String?   @map("report_type")
  serviceType    String?   @map("service_type")
  smr            Int?
  performedBy    String?   @map("performed_by")
  operationDate  DateTime? @map("operation_date")
  machine        EqpMachine? @relation(fields: [machineId], references: [id])
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdById    String?   @map("created_by")
  updatedById    String?   @map("updated_by")

  @@index([machineId])
  @@index([createdAt])
  @@map("eqp_machine_history")
}

model EqpReportComment {
  id          Int      @id @default(autoincrement())
  commentText String   @map("comment_text")
  frequency   Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  @@map("eqp_report_comments")
}
