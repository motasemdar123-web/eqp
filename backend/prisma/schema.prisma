generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  GENERAL_MANAGER
  OPERATIONS_MANAGER
  MAINTENANCE_SUPERVISOR
  FIELD_TECHNICIAN
  CALL_CENTER
  WAREHOUSE_OFFICER
  FINANCE
  CLIENT
  SYSTEM_ADMIN
}

enum Permission {
  USERS_MANAGE
  REQUESTS_CREATE
  REQUESTS_READ
  REQUESTS_ASSIGN
  REQUESTS_APPROVE
  WORK_ORDERS_MANAGE
  WORK_ORDERS_CLOSE
  ASSETS_MANAGE
  INVENTORY_MANAGE
  SCHEDULE_MANAGE
  REPORTS_READ
  EQP_MANAGE
  SYSTEM_CONFIGURE
}

enum RequestStatus {
  NEW
  TRIAGED
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CLOSED
  REOPENED
  CANCELLED
  MERGED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RequestSource {
  PHONE
  EMAIL
  WHATSAPP
  PORTAL
  TECHNICIAN
  PREVENTIVE_MAINTENANCE
  MANAGEMENT
}

enum WorkOrderStatus {
  DRAFT
  OPEN
  ASSIGNED
  IN_PROGRESS
  WAITING_PARTS
  PENDING_APPROVAL
  COMPLETED
  CLOSED
  CANCELLED
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  RETIRED
  LOST
}

enum InventoryTransactionType {
  ISSUE
  RETURN
  TRANSFER
  ADJUSTMENT
  PURCHASE_RECEIPT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

model User {
  id           String      @id @default(uuid())
  email        String?     @unique
  userNumber   Int?        @unique
  fullName     String
  passwordHash String?
  isActive     Boolean     @default(true)
  roles        UserRole[]
  technician   Technician?
  clientId     String?
  client       Client?     @relation(fields: [clientId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  createdRequests   MaintenanceRequest[] @relation("CreatedRequests")
  assignedWorkOrders WorkOrder[]         @relation("AssignedTechnician")
  auditLogs          AuditLog[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  role      Role
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, role])
}

model RolePermission {
  id         String     @id @default(uuid())
  role       Role
  permission Permission

  @@unique([role, permission])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model Client {
  id        String    @id @default(uuid())
  name      String
  code      String?   @unique
  contacts  Json?
  users     User[]
  projects  Project[]
  branches  Branch[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id        String   @id @default(uuid())
  clientId  String
  name      String
  code      String?
  client    Client   @relation(fields: [clientId], references: [id])
  branches  Branch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id        String     @id @default(uuid())
  clientId  String?
  projectId String?
  name      String
  code      String?
  address   String?
  latitude  Decimal?
  longitude Decimal?
  client    Client?    @relation(fields: [clientId], references: [id])
  project   Project?   @relation(fields: [projectId], references: [id])
  locations Location[]
  requests  MaintenanceRequest[]
  assets    Asset[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Location {
  id        String   @id @default(uuid())
  branchId  String?
  name      String
  type      String?
  floor     String?
  unit      String?
  latitude  Decimal?
  longitude Decimal?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  assets    Asset[]
  requests  MaintenanceRequest[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id                String      @id @default(uuid())
  assetCode         String      @unique
  name              String
  category          String?
  serialNumber      String?
  qrCode            String?
  warrantyUntil     DateTime?
  purchaseDate      DateTime?
  lifecycleStatus   AssetStatus @default(ACTIVE)
  branchId          String?
  locationId        String?
  accumulatedCost   Decimal?    @default(0)
  branch            Branch?     @relation(fields: [branchId], references: [id])
  location          Location?   @relation(fields: [locationId], references: [id])
  requests          MaintenanceRequest[]
  workOrders        WorkOrder[]
  preventivePlans   PreventiveMaintenancePlan[]
  linkedParts       AssetSparePart[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model MaintenanceRequest {
  id                   String        @id @default(uuid())
  requestNumber        String        @unique
  title                String
  description          String?
  category             String
  priority             Priority      @default(MEDIUM)
  status               RequestStatus @default(NEW)
  source               RequestSource @default(PORTAL)
  slaTargetAt          DateTime?
  branchId             String?
  locationId           String?
  assetId              String?
  createdById          String?
  customerVisibleNotes String?
  internalNotes        String?
  duplicateOfId        String?
  recurringGroupId     String?
  reopenCount          Int           @default(0)
  branch               Branch?       @relation(fields: [branchId], references: [id])
  location             Location?     @relation(fields: [locationId], references: [id])
  asset                Asset?        @relation(fields: [assetId], references: [id])
  createdBy            User?         @relation("CreatedRequests", fields: [createdById], references: [id])
  workOrders           WorkOrder[]
  attachments          Attachment[]
  timeline             TimelineEvent[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model WorkOrder {
  id                   String          @id @default(uuid())
  workOrderNumber      String          @unique
  requestId            String?
  assetId              String?
  title                String
  description          String?
  status               WorkOrderStatus @default(OPEN)
  priority             Priority        @default(MEDIUM)
  assignedTechnicianId String?
  teamName             String?
  scheduledStartAt     DateTime?
  scheduledEndAt       DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  laborMinutes         Int             @default(0)
  closureNotes         String?
  qualityApprovedAt    DateTime?
  qualityApprovedBy    String?
  rootCause            String?
  correctiveAction     String?
  preventiveAction     String?
  request              MaintenanceRequest? @relation(fields: [requestId], references: [id])
  asset                Asset?          @relation(fields: [assetId], references: [id])
  assignedTechnician   User?           @relation("AssignedTechnician", fields: [assignedTechnicianId], references: [id])
  materials            WorkOrderMaterial[]
  checklists           WorkOrderChecklistItem[]
  attachments          Attachment[]
  timeline             TimelineEvent[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model WorkOrderChecklistItem {
  id          String    @id @default(uuid())
  workOrderId String
  label       String
  internalKey String?
  isRequired  Boolean   @default(false)
  completedAt DateTime?
  completedBy String?
  notes       String?
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model Technician {
  id             String   @id @default(uuid())
  userId         String   @unique
  employeeCode   String?  @unique
  region         String?
  shift          String?
  skills         String[]
  certifications Json?
  isAvailable    Boolean  @default(true)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PreventiveMaintenancePlan {
  id        String    @id @default(uuid())
  name      String
  assetId   String?
  frequency Frequency
  checklist Json?
  nextDueAt DateTime?
  isActive  Boolean   @default(true)
  asset     Asset?    @relation(fields: [assetId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model SparePart {
  id               String   @id @default(uuid())
  partNumber       String   @unique
  name             String
  unit             String
  cost             Decimal? @default(0)
  reorderThreshold Int      @default(0)
  stockItems       StockItem[]
  linkedAssets     AssetSparePart[]
  materials        WorkOrderMaterial[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Warehouse {
  id        String      @id @default(uuid())
  name      String
  code      String?     @unique
  stock     StockItem[]
  logs      WarehouseLog[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model StockItem {
  id          String    @id @default(uuid())
  sparePartId String
  warehouseId String
  quantity    Int       @default(0)
  sparePart   SparePart @relation(fields: [sparePartId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([sparePartId, warehouseId])
}

model WarehouseLog {
  id          String                   @id @default(uuid())
  warehouseId String
  sparePartId String?
  type        InventoryTransactionType
  quantity    Int
  reference   String?
  cost        Decimal?
  metadata    Json?
  warehouse   Warehouse                @relation(fields: [warehouseId], references: [id])
  createdAt   DateTime                 @default(now())
}

model WorkOrderMaterial {
  id          String    @id @default(uuid())
  workOrderId String
  sparePartId String
  quantity    Int
  unitCost    Decimal?  @default(0)
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  sparePart   SparePart @relation(fields: [sparePartId], references: [id])
}

model AssetSparePart {
  id          String    @id @default(uuid())
  assetId     String
  sparePartId String
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  sparePart   SparePart @relation(fields: [sparePartId], references: [id], onDelete: Cascade)

  @@unique([assetId, sparePartId])
}

model Notification {
  id        String              @id @default(uuid())
  userId    String?
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(PENDING)
  title     String
  message   String
  metadata  Json?
  createdAt DateTime            @default(now())
  readAt    DateTime?
}

model EscalationRule {
  id          String   @id @default(uuid())
  name        String
  triggerType String
  conditions  Json
  actions     Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attachment {
  id          String   @id @default(uuid())
  requestId   String?
  workOrderId String?
  fileName    String
  fileUrl     String
  mimeType    String?
  category    String?
  uploadedBy  String?
  request     MaintenanceRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  workOrder   WorkOrder?          @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model TimelineEvent {
  id          String   @id @default(uuid())
  requestId   String?
  workOrderId String?
  actorId     String?
  eventType   String
  message     String
  metadata    Json?
  request     MaintenanceRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  workOrder   WorkOrder?          @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

// Existing EQP compatibility models. These map to the current production tables.
model EqpMachine {
  id                   Int     @id @default(autoincrement())
  machine_number       String?
  engine_number        String?
  machine_type         String?
  last_smr             Int?
  smr_step             Int?
  report_counter       Int?
  responsible_engineer String?

  @@map("machines")
}

model EqpReport {
  id             Int       @id @default(autoincrement())
  report_no      String?
  machine_type   String?
  machine_id     Int?
  engine_number  String?
  smr            Int?
  service_date   DateTime?
  comments       String?
  created_by     String?
  machine_number String?
  report_type    String?
  service_type   String?
  file_name      String?
  file_url       String?
  created_at     DateTime? @default(now())

  @@map("reports")
}

model EqpMachineHistory {
  id             Int       @id @default(autoincrement())
  machine_id     Int?
  operation_type String?
  report_type    String?
  service_type   String?
  smr            Int?
  performed_by   String?
  operation_date DateTime?
  created_at     DateTime? @default(now())

  @@map("machine_history")
}

model EqpReportComment {
  id           Int     @id @default(autoincrement())
  comment_text String?
  frequency    Int?

  @@map("report_comments")
}
