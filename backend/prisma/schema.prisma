generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
}

enum RoleCode {
  SUPER_ADMIN
  GENERAL_MANAGER
  OPERATIONS_MANAGER
  SERVICE_ENGINEER
  MAINTENANCE_SUPERVISOR
  TECHNICIAN
  FIELD_TECHNICIAN
  CALL_CENTER
  WAREHOUSE_OFFICER
  FINANCE
  CLIENT
  SYSTEM_ADMIN
}

enum PermissionCode {
  USERS_MANAGE
  REQUESTS_CREATE
  REQUESTS_READ
  REQUESTS_ASSIGN
  REQUESTS_APPROVE
  WORK_ORDERS_MANAGE
  WORK_ORDERS_CLOSE
  ASSETS_MANAGE
  INVENTORY_MANAGE
  SCHEDULE_MANAGE
  REPORTS_READ
  EQP_MANAGE
  SYSTEM_CONFIGURE
}

enum TechnicianScheduleStatus {
  PLANNED
  CONFIRMED
  ON_DUTY
  OFF_DUTY
  LEAVE
  COMPLETED
  CANCELLED
}

model User {
  id           String             @id @default(uuid())
  email        String             @unique
  userNumber   Int?               @unique @map("user_number")
  fullName     String             @map("full_name")
  passwordHash String             @map("password_hash")
  phone        String?
  locale       String             @default("en")
  status       UserStatus         @default(ACTIVE)
  roles        UserRole[]
  technician   TechnicianProfile?
  engineerTaskAssignments DailyScheduleTaskEngineer[]
  plannerTaskPushes PlannerTaskPush[] @relation("PlannerTaskAssignee")
  plannerTaskPushesCreated PlannerTaskPush[] @relation("PlannerTaskCreator")
  notifications Notification[]
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  createdById  String?            @map("created_by")
  updatedById  String?            @map("updated_by")
  deletedAt    DateTime?          @map("deleted_at")

  @@map("users")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    @default("SYSTEM")
  severity    String    @default("info")
  title       String
  message     String
  href        String?
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  createdById String?   @map("created_by")
  deletedAt   DateTime? @map("deleted_at")

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Role {
  id          String           @id @default(uuid())
  code        RoleCode         @unique
  name        String
  description String?
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  createdById String?          @map("created_by")
  updatedById String?          @map("updated_by")
  deletedAt   DateTime?        @map("deleted_at")

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  code        PermissionCode   @unique
  name        String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  createdById String?          @map("created_by")
  updatedById String?          @map("updated_by")
  deletedAt   DateTime?        @map("deleted_at")

  @@map("permissions")
}

model UserRole {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  roleId      String   @map("role_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by")

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")
  createdById  String?    @map("created_by")

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Branch {
  id                  String               @id @default(uuid())
  code                String               @unique
  name                String
  nameAr              String?              @map("name_ar")
  address             String?
  shifts              Shift[]
  technicianSchedules TechnicianSchedule[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  createdById         String?              @map("created_by")
  updatedById         String?              @map("updated_by")
  deletedAt           DateTime?            @map("deleted_at")

  @@map("branches")
}

model Shift {
  id          String               @id @default(uuid())
  branchId    String?              @map("branch_id")
  name        String
  startsAt    String               @map("starts_at")
  endsAt      String               @map("ends_at")
  branch      Branch?              @relation(fields: [branchId], references: [id])
  technicians TechnicianProfile[]
  schedules   TechnicianSchedule[]
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  createdById String?              @map("created_by")
  updatedById String?              @map("updated_by")
  deletedAt   DateTime?            @map("deleted_at")

  @@unique([branchId, name])
  @@index([branchId])
  @@map("shifts")
}

model TechnicianProfile {
  id              String                        @id @default(uuid())
  userId          String                        @unique @map("user_id")
  employeeCode    String?                       @unique @map("employee_code")
  region          String?
  shiftId         String?                       @map("shift_id")
  isAvailable     Boolean                       @default(true) @map("is_available")
  user            User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift           Shift?                        @relation(fields: [shiftId], references: [id])
  skills          TechnicianSkill[]
  schedules       TechnicianSchedule[]
  taskAssignments DailyScheduleTaskTechnician[]
  createdAt       DateTime                      @default(now()) @map("created_at")
  updatedAt       DateTime                      @updatedAt @map("updated_at")
  createdById     String?                       @map("created_by")
  updatedById     String?                       @map("updated_by")
  deletedAt       DateTime?                     @map("deleted_at")

  @@index([shiftId])
  @@map("technician_profiles")
}

model TechnicianSkill {
  id             String            @id @default(uuid())
  technicianId   String            @map("technician_id")
  skill          String
  level          String?
  certificateUrl String?           @map("certificate_url")
  technician     TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  createdById    String?           @map("created_by")
  updatedById    String?           @map("updated_by")

  @@unique([technicianId, skill])
  @@index([skill])
  @@map("technician_skills")
}

model TechnicianSchedule {
  id           String                   @id @default(uuid())
  technicianId String                   @map("technician_id")
  shiftId      String?                  @map("shift_id")
  branchId     String?                  @map("branch_id")
  workDate     DateTime                 @map("work_date") @db.Date
  startsAt     String                   @map("starts_at")
  endsAt       String                   @map("ends_at")
  status       TechnicianScheduleStatus @default(PLANNED)
  notes        String?
  technician   TechnicianProfile        @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  shift        Shift?                   @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  branch       Branch?                  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")
  createdById  String?                  @map("created_by")
  updatedById  String?                  @map("updated_by")
  deletedAt    DateTime?                @map("deleted_at")

  @@unique([technicianId, workDate])
  @@index([workDate])
  @@index([branchId, workDate])
  @@index([shiftId])
  @@map("technician_schedules")
}

model DailyScheduleTask {
  id           String                        @id @default(uuid())
  workDate     DateTime                      @map("work_date") @db.Date
  task         String
  description  String?
  checklist    Json?
  machineModel String?                       @map("machine_model")
  manualAdvice Json?                         @map("manual_advice")
  location     String?
  startsAt     String                        @map("starts_at")
  endsAt       String                        @map("ends_at")
  status       TechnicianScheduleStatus      @default(CONFIRMED)
  notes        String?
  startedAt    DateTime?                     @map("started_at")
  completedAt  DateTime?                     @map("completed_at")
  summary      String?
  photos       Json?
  checklistReports Json?                     @map("checklist_reports")
  technicians  DailyScheduleTaskTechnician[]
  engineers    DailyScheduleTaskEngineer[]
  createdAt    DateTime                      @default(now()) @map("created_at")
  updatedAt    DateTime                      @updatedAt @map("updated_at")
  createdById  String?                       @map("created_by")
  updatedById  String?                       @map("updated_by")
  deletedAt    DateTime?                     @map("deleted_at")

  @@index([workDate])
  @@index([status])
  @@map("daily_schedule_tasks")
}

model ShopManual {
  id                     String            @id @default(uuid())
  machineModel           String            @map("machine_model")
  title                  String
  fileName               String?           @map("file_name")
  manualType             String?           @map("manual_type")
  serialRange            String?           @map("serial_range")
  revision               String?
  language               String?           @default("en")
  sourceType             String            @default("PDF") @map("source_type")
  status                 String            @default("INDEXED")
  openaiFileId           String?           @map("openai_file_id")
  openaiVectorStoreId    String?           @map("openai_vector_store_id")
  openaiVectorFileId     String?           @map("openai_vector_file_id")
  openaiIndexStatus      String            @default("LOCAL_ONLY") @map("openai_index_status")
  openaiLastError        String?           @map("openai_last_error")
  manualMetadata         Json?             @map("metadata")
  originalPdf            Bytes?            @map("original_pdf")
  originalPdfSize        Int?              @map("original_pdf_size")
  originalPdfContentType String?           @map("original_pdf_content_type")
  originalStoredAt       DateTime?         @map("original_stored_at")
  chunks                 ShopManualChunk[]
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  createdById            String?           @map("created_by")
  updatedById            String?           @map("updated_by")
  deletedAt              DateTime?         @map("deleted_at")

  @@index([machineModel])
  @@map("shop_manuals")
}

model ShopManualChunk {
  id           String     @id @default(uuid())
  manualId     String     @map("manual_id")
  machineModel String     @map("machine_model")
  pageNumber   Int?       @map("page_number")
  section      String?
  content      String
  manual       ShopManual @relation(fields: [manualId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([manualId])
  @@index([machineModel])
  @@map("shop_manual_chunks")
}

model DailyScheduleTaskTechnician {
  id           String            @id @default(uuid())
  taskId       String            @map("task_id")
  technicianId String            @map("technician_id")
  task         DailyScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  technician   TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now()) @map("created_at")
  createdById  String?           @map("created_by")

  @@unique([taskId, technicianId])
  @@index([technicianId])
  @@map("daily_schedule_task_technicians")
}

model DailyScheduleTaskEngineer {
  id          String            @id @default(uuid())
  taskId      String            @map("task_id")
  engineerId  String            @map("engineer_id")
  task        DailyScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  engineer    User              @relation(fields: [engineerId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now()) @map("created_at")
  createdById String?           @map("created_by")

  @@unique([taskId, engineerId])
  @@index([engineerId])
  @@map("daily_schedule_task_engineers")
}

model PlannerTaskPush {
  id                      String    @id @default(uuid())
  title                   String
  description             String?
  suggestedDate           DateTime? @map("suggested_date") @db.Date
  suggestedTime           String?   @map("suggested_time")
  expectedDurationMinutes Int       @default(0) @map("expected_duration_minutes")
  status                  String    @default("PENDING")
  plannedDate             DateTime? @map("planned_date") @db.Date
  plannedTime             String?   @map("planned_time")
  assigneeId              String    @map("assignee_id")
  createdById             String    @map("created_by")
  assignee                User      @relation("PlannerTaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  createdBy               User      @relation("PlannerTaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  @@index([assigneeId, status])
  @@index([createdById])
  @@map("planner_task_pushes")
}

model EqpMachine {
  id                  Int                 @id @default(autoincrement())
  machineNumber       String              @unique @map("machine_number")
  engineNumber        String?             @map("engine_number")
  machineType         String?             @map("machine_type")
  lastSmr             Int                 @default(0) @map("last_smr")
  smrStep             Int                 @default(0) @map("smr_step")
  reportCounter       Int                 @default(0) @map("report_counter")
  responsibleEngineer String?             @map("responsible_engineer")
  reports             EqpReport[]
  history             EqpMachineHistory[]
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  createdById         String?             @map("created_by")
  updatedById         String?             @map("updated_by")
  deletedAt           DateTime?           @map("deleted_at")

  @@index([machineType])
  @@map("eqp_machines")
}

model EqpReport {
  id            Int         @id @default(autoincrement())
  reportNo      String      @unique @map("report_no")
  machineType   String?     @map("machine_type")
  machineId     Int?        @map("machine_id")
  engineNumber  String?     @map("engine_number")
  smr           Int?
  serviceDate   DateTime?   @map("service_date")
  comments      String?
  createdByName String?     @map("created_by")
  machineNumber String?     @map("machine_number")
  reportType    String?     @map("report_type")
  serviceType   String?     @map("service_type")
  fileName      String?     @map("file_name")
  fileUrl       String?     @map("file_url")
  machine       EqpMachine? @relation(fields: [machineId], references: [id])
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  createdById   String?     @map("created_by_user")
  updatedById   String?     @map("updated_by_user")
  deletedAt     DateTime?   @map("deleted_at")

  @@index([machineId])
  @@index([createdAt])
  @@index([serviceType])
  @@map("eqp_reports")
}

model EqpMachineHistory {
  id            Int         @id @default(autoincrement())
  machineId     Int?        @map("machine_id")
  operationType String?     @map("operation_type")
  reportType    String?     @map("report_type")
  serviceType   String?     @map("service_type")
  smr           Int?
  performedBy   String?     @map("performed_by")
  operationDate DateTime?   @map("operation_date")
  machine       EqpMachine? @relation(fields: [machineId], references: [id])
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  createdById   String?     @map("created_by")
  updatedById   String?     @map("updated_by")

  @@index([machineId])
  @@index([createdAt])
  @@map("eqp_machine_history")
}

model EqpReportComment {
  id          Int      @id @default(autoincrement())
  commentText String   @unique @map("comment_text")
  frequency   Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  @@map("eqp_report_comments")
}
